#!/bin/bash
# run_once_ssh-keygen.sh.tmpl
#
# Generates an ed25519 SSH key if one doesn't already exist.
# Runs once per machine — won't overwrite a key you've already set up.

set -e

KEY="$HOME/.ssh/id_ed25519"

if [ -f "$KEY" ]; then
  echo "==> SSH key already exists at $KEY, skipping."
  exit 0
fi

echo "==> Generating SSH key..."
mkdir -p "$HOME/.ssh"
chmod 700 "$HOME/.ssh"

ssh-keygen -t ed25519 -C "{{ .email }}" -f "$KEY" -N ""

# Add to the macOS Keychain so you're not prompted on every new session
ssh-add --apple-use-keychain "$KEY" 2>/dev/null || ssh-add "$KEY"

echo ""
echo "╔══════════════════════════════════════════════╗"
echo "║  SSH key generated — action required!        ║"
echo "╚══════════════════════════════════════════════╝"
echo ""
echo "Add this public key to GitHub:"
echo "  https://github.com/settings/ssh/new"
echo ""
cat "$KEY.pub"
echo ""
