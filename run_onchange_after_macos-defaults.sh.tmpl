#!/bin/bash
# run_onchange_after_macos-defaults.sh.tmpl
#
# Applies macOS system preferences automatically.
# The `after_` prefix ensures this runs after dotfiles are applied.
# Re-runs automatically whenever this file's content changes.
#
# Profiles:
#   minimal   — keyboard fixes, security, software updates, screenshots
#   secondary — minimal + Finder preferences
#   primary   — everything (Dock, Mission Control, menu bar, Night Shift, Chrome)

{{- if eq .chezmoi.os "darwin" }}

set -e

echo ""
echo "╔══════════════════════════════════════════════╗"
echo "║  Applying macOS defaults  [{{ .profile }}]"
echo "╚══════════════════════════════════════════════╝"

# ── Computer Identity ──────────────────────────────────────────────────────────
echo "==> Setting computer name to '{{ .computerName }}'..."
sudo scutil --set ComputerName  "{{ .computerName }}"
sudo scutil --set HostName      "{{ .computerName }}"
sudo scutil --set LocalHostName "{{ .computerName }}"
dscacheutil -flushcache

# ── Screenshots ───────────────────────────────────────────────────────────────
echo "==> Configuring screenshots..."
mkdir -p "{{ .chezmoi.homeDir }}/Documents/Screenshots"
defaults write com.apple.screencapture location -string "{{ .chezmoi.homeDir }}/Documents/Screenshots"
defaults write com.apple.screencapture type -string "png"

# ── Keyboard & Input ──────────────────────────────────────────────────────────
echo "==> Configuring keyboard..."
defaults write NSGlobalDomain KeyRepeat -int 2
defaults write NSGlobalDomain InitialKeyRepeat -int 15
defaults write NSGlobalDomain NSAutomaticCapitalizationEnabled   -bool false
defaults write NSGlobalDomain NSAutomaticDashSubstitutionEnabled -bool false
defaults write NSGlobalDomain NSAutomaticPeriodSubstitutionEnabled -bool false
defaults write NSGlobalDomain NSAutomaticQuoteSubstitutionEnabled -bool false

# ── Security & Privacy ────────────────────────────────────────────────────────
echo "==> Configuring security..."
defaults write com.apple.LaunchServices LSQuarantine -bool false
defaults write com.apple.screensaver askForPassword      -int 1
defaults write com.apple.screensaver askForPasswordDelay -int 0
sudo systemsetup -setrestartfreeze on 2>/dev/null || true

# Enable Touch ID for sudo (uses sudo_local which survives macOS updates)
if ! grep -q "pam_tid.so" /etc/pam.d/sudo_local 2>/dev/null; then
  echo "auth       sufficient     pam_tid.so" | sudo tee /etc/pam.d/sudo_local > /dev/null
fi

# ── Software Updates ──────────────────────────────────────────────────────────
echo "==> Configuring software updates..."
defaults write com.apple.SoftwareUpdate AutomaticCheckEnabled -bool true
defaults write com.apple.SoftwareUpdate ScheduleFrequency     -int 1
defaults write com.apple.SoftwareUpdate AutomaticDownload     -int 1
defaults write com.apple.SoftwareUpdate CriticalUpdateInstall -int 1
defaults write com.apple.commerce AutoUpdate                  -bool true
defaults write com.apple.commerce AutoUpdateRestartRequired   -bool true

# ── Finder (secondary + primary) ──────────────────────────────────────────────
{{- if ne .profile "minimal" }}
echo "==> Configuring Finder..."

defaults write com.apple.finder AppleShowAllFiles         -bool true
defaults write NSGlobalDomain   AppleShowAllExtensions    -bool true
defaults write com.apple.finder ShowPathbar               -bool true
defaults write com.apple.finder ShowStatusBar             -bool true
defaults write com.apple.finder FXPreferredViewStyle      -string "Nlsv"
defaults write com.apple.finder FXEnableExtensionChangeWarning -bool false

defaults write com.apple.finder ShowHardDrivesOnDesktop         -bool false
defaults write com.apple.finder ShowExternalHardDrivesOnDesktop -bool false
defaults write com.apple.finder ShowMountedServersOnDesktop     -bool false
defaults write com.apple.finder ShowRemovableMediaOnDesktop     -bool false

defaults write com.apple.desktopservices DSDontWriteNetworkStores -bool true
defaults write com.apple.desktopservices DSDontWriteUSBStores     -bool true

defaults write com.apple.frameworks.diskimages auto-open-ro-root -bool true
defaults write com.apple.frameworks.diskimages auto-open-rw-root -bool true
defaults write com.apple.finder OpenWindowForNewRemovableDisk    -bool true

# Snap-to-grid for icons on the desktop and in other icon views
for VIEW_KEY in DesktopViewSettings FK_StandardViewSettings StandardViewSettings; do
  /usr/libexec/PlistBuddy \
    -c "Set :${VIEW_KEY}:IconViewSettings:arrangeBy grid" \
    ~/Library/Preferences/com.apple.finder.plist 2>/dev/null || \
  /usr/libexec/PlistBuddy \
    -c "Add :${VIEW_KEY}:IconViewSettings:arrangeBy string grid" \
    ~/Library/Preferences/com.apple.finder.plist 2>/dev/null || true
done
{{- end }}

# ── Dock (primary only) ────────────────────────────────────────────────────────
{{- if eq .profile "primary" }}
echo "==> Configuring Dock..."
defaults write com.apple.dock autohide                  -bool true
defaults write com.apple.dock autohide-delay            -float 0
defaults write com.apple.dock autohide-time-modifier    -float 0.4
defaults write com.apple.dock show-recents              -bool false
defaults write com.apple.dock minimize-to-application   -bool true
defaults write com.apple.dock expose-group-by-app       -bool true
defaults write com.apple.dock mru-spaces                -bool false
{{- end }}

# ── Menu Bar (primary only) ───────────────────────────────────────────────────
{{- if eq .profile "primary" }}
echo "==> Configuring menu bar..."
defaults write com.apple.menuextra.clock IsAnalog      -bool false
defaults write com.apple.menuextra.clock ShowDate      -int 1
defaults write com.apple.menuextra.clock ShowDayOfWeek -bool false
defaults write com.apple.menuextra.clock ShowSeconds   -bool true
defaults write com.apple.Spotlight MenuItemHidden      -int 1
{{- end }}

# ── Night Shift (primary only) ────────────────────────────────────────────────
{{- if eq .profile "primary" }}
echo "==> Configuring Night Shift..."
HW_UUID=$(system_profiler SPHardwareDataType 2>/dev/null | awk '/Hardware UUID:/ { print $3 }')
CBPLIST="$HOME/Library/Preferences/com.apple.CoreBrightness.plist"
if [ -n "$HW_UUID" ]; then
  /usr/libexec/PlistBuddy \
    -c "Set :CBUser-${HW_UUID}:CBBlueLightSchedule:scheduleType 2" "$CBPLIST" 2>/dev/null || \
  /usr/libexec/PlistBuddy \
    -c "Add :CBUser-${HW_UUID}:CBBlueLightSchedule:scheduleType integer 2" "$CBPLIST" 2>/dev/null || true
  /usr/libexec/PlistBuddy \
    -c "Set :CBUser-${HW_UUID}:CBBlueLightSchedule:enabled true" "$CBPLIST" 2>/dev/null || \
  /usr/libexec/PlistBuddy \
    -c "Add :CBUser-${HW_UUID}:CBBlueLightSchedule:enabled bool true" "$CBPLIST" 2>/dev/null || true
  echo "  Night Shift set to Sunset to Sunrise for UUID: $HW_UUID"
else
  echo "  ⚠ Could not determine hardware UUID; Night Shift schedule not set."
  echo "  Enable manually: System Settings → Displays → Night Shift → Sunset to Sunrise."
fi
{{- end }}

# ── Google Chrome (primary only) ──────────────────────────────────────────────
{{- if eq .profile "primary" }}
echo "==> Configuring Google Chrome..."
defaults write com.google.Chrome        DisablePrintPreview -bool true
defaults write com.google.Chrome.canary DisablePrintPreview -bool true
{{- end }}

# ── Apply changes ─────────────────────────────────────────────────────────────
echo "==> Restarting affected services..."
{{- if ne .profile "minimal" }}
killall Finder         2>/dev/null || true
{{- end }}
{{- if eq .profile "primary" }}
killall Dock           2>/dev/null || true
killall SystemUIServer 2>/dev/null || true
{{- end }}

echo ""
echo "✓ macOS defaults applied (profile: {{ .profile }})."
echo "  Note: Some changes may require a logout or restart to fully take effect."
{{- if eq .profile "primary" }}
echo "  Night Shift changes will apply after re-login."
{{- end }}

{{- end }}
